{
  "name": "project-mind",
  "version": "1.0.0",
  "description": "Deterministic project intelligence and AI handoff generator",
  "type": "module",
  "bin": {
    "project-mind": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",

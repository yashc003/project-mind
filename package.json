{
  "name": "project-mind",
  "version": "1.1.1",
  "description": "Deterministic project intelligence and AI handoff generator",
  "type": "module",
  "bin": {
    "project-mind": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run --fileParallelism false",
    "test:e2e": "npm run build && vitest run tests/e2e --fileParallelism false",
    "test:watch": "vitest --fileParallelism false",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "context",
    "project-intelligence",
    "memory",
    "handoff",
    "developer-tools",
    "cli",
    "git",
    "architecture",
    "code-understanding"
  ],
  "author": "Yash",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yashc003/project-mind.git"
  },
  "bugs": {
    "url": "https://github.com/yashc003/project-mind/issues"
  },
  "homepage": "https://github.com/yashc003/project-mind#readme",
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "handlebars": "^4.7.8",
    "ora": "^8.1.0",
    "simple-git": "^3.27.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.20.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
